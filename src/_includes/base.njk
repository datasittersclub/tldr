<!DOCTYPE html>
<html lang="zxx">
  <head>
    <meta charset="utf-8" />
    <title>Data-Sitters tl;dr</title>
    <meta name="generator" content="Eleventy">
    <meta name="robots" content="index,follow,max-image-preview:large" />

    <!-- mobile responsive meta -->
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, maximum-scale=1"
    />

    {% set siteBaseUrl = "https://datasittersclub.github.io" %}
    {% set canonicalUrl = siteBaseUrl + (page.url | url) %}

    {% set socialImage = ogImg or featureImg1 %}
    {% if socialImage %}
      {% set previewImageUrl = socialImage %}
      {% if socialImage[0] == "/" %}
        {% set previewImageUrl = siteBaseUrl + socialImage %}
      {% endif %}
      {% set previewImageTagUrl = previewImageUrl ~ "?v=20260409-2" %}
    {% endif %}

    <meta property="og:title" content="{{ title | default('Data-Sitters tl;dr') }}" />
    <meta property="og:description" content="{{ subTitle | default('Just enough digital humanities to get started.') }}" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="{{ canonicalUrl }}" />
    <link rel="canonical" href="{{ canonicalUrl }}" />
    <meta name="twitter:card" content="{{ socialImage and 'summary_large_image' or 'summary' }}" />
    <meta name="twitter:title" content="{{ title | default('Data-Sitters tl;dr') }}" />
    <meta name="twitter:description" content="{{ subTitle | default('Just enough digital humanities to get started.') }}" />

    {% if socialImage %}
    <meta property="og:image" content="{{ previewImageTagUrl }}" />
    <meta property="og:image:secure_url" content="{{ previewImageTagUrl }}" />
    <meta property="og:image:type" content="image/jpeg" />
    {% if ogImgWidth %}<meta property="og:image:width" content="{{ ogImgWidth }}" />{% endif %}
    {% if ogImgHeight %}<meta property="og:image:height" content="{{ ogImgHeight }}" />{% endif %}
    <meta name="twitter:image" content="{{ previewImageTagUrl }}" />
    {% endif %}

    <!-- Slick Carousel -->
    <link rel="stylesheet" href="{{ '/assets/vendor/slick/slick.css' | url }}" />
    <link rel="stylesheet" href="{{ '/assets/vendor/slick/slick-theme.css' | url }}" />
    <!-- Font Awesome -->
    <link
      rel="stylesheet"
      href="{{ '/assets/vendor/font-awesome/css/font-awesome.min.css' | url }}"
    />
    <!-- Bootstrap -->
    <link rel="stylesheet" href="{{ '/assets/vendor/bootstrap/bootstrap.min.css' | url }}" />
    <!-- Stylesheets -->
    <link href="{{ '/assets/css/style.css' | url }}" rel="stylesheet" />

    <!--Favicon-->
    <link rel="shortcut icon" href="{{ '/assets/images/favIcon.png' | url }}" type="image/x-icon" />
    <link rel="icon" href="{{ '/assets/images/favIcon.png' | url }}" type="image/x-icon" />
  </head>

  <body{% block bodyAttrs %}{% endblock %}>
  {% block navbar %}
    <nav class="navbar navbar-expand-lg site-navigation">
      <div class="container">
        <a class="navbar-brand" href="https://datasittersclub.github.io/site/">
          <img src="{{nav.navLogo}}" alt="nav-logo" />
        </a>
        <button
          class="navbar-toggler collapsed"
          type="button"
          data-toggle="collapse"
          data-target="#sitenavbar"
        >
          <span class="icon-bar"></span>
          <span class="icon-bar"></span>
          <span class="icon-bar"></span>
        </button>
      
        <div class="collapse navbar-collapse" id="sitenavbar">
          <ul class="navbar-nav ml-auto main-nav">
            <li class="nav-item">
                <a class="nav-link" href="{{ '/' | url }}">tl;dr home</a>
            </li>
                        <li class="nav-item">
                <a class="nav-link" href="{{ '/about/' | url }}">about</a> 
            </li>
                            
            
          </ul>
        </div>
      </div>
    </nav>
  {% endblock %}

  {% block content %}
    {{content | safe}}
  {% endblock %}

  

  
    <!-- <script src="js/vendor.js"></script> -->
    <script src="{{ '/assets/vendor/jQuery/jquery.min.js' | url }}"></script>
    <script src="{{ '/assets/vendor/bootstrap/bootstrap.min.js' | url }}"></script>
    <script src="{{ '/assets/js/script.js' | url }}"></script>
  </body>
</html>

