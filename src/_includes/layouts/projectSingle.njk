{% extends "base.njk" %}

{% block bodyAttrs %} style="background-color: {{ bgcolor | default('#ffffff') }};"{% endblock %}

{% block content %}

    <section class="site-project-single-section">
      <div class="container">
        <div class="row">
          
          <div class="col-12 project-single-main mx-auto">
          <h1 class="booktitle">
                {{title}}
              </h1>
            <div class="site-project-single">
            
                                        <div class="site-project-single-image">
                <img src="{{featureImg1}}" class="bookcover" alt="book cover" />
              </div>
              <div class="site-project-single-description">
                {{content | safe}}
              </div>
              {% if collections.portfolios %}
              {% set nextPost = collections.portfolios | getNextCollectionItem(page) %}
              {% set previousPost = collections.portfolios | getPreviousCollectionItem(page) %}
              
              <div class="site-project-single-action d-flex justify-content-between">
                {% if previousPost%}
                <a href="{{previousPost.url | url}}">
                  <img class="rev" src="{{ '/assets/images/to-top.svg' | url }}" alt="next project">
                  <span class="link-area">
                    <span data-text="{{previousPost.data.title}}">
                      Previous Project
                    </span>
                  </span>
                </a>
                {% endif %}
                {% if nextPost %}
                <a href="{{nextPost.url | url}}">
                  <span class="link-area">
                    <span data-text="{{nextPost.data.title}}">
                      Next Project
                    </span>
                  </span>
                  <img src="{{ '/assets/images/to-top.svg' | url }}" alt="next project">
                </a> 
                {% endif %} 
              </div>
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    </section>
  
{% endblock %}